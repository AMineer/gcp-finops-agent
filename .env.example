# GCP Configuration
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated list of GCP project IDs for Recommender API scope
GCP_PROJECT_SCOPE=your-project-a,your-project-b

# BigQuery billing export table identifiers (fully-qualified: project.dataset.table)
# See: https://cloud.google.com/billing/docs/how-to/export-data-bigquery
GCP_BILLING_DATASET=your-billing-project.your_billing_dataset.gcp_billing_export_v1_XXXXXX
GCP_DETAILED_BILLING_DATASET=your-billing-project.your_billing_dataset.gcp_billing_export_resource_v1_XXXXXX

# Agent Engine staging bucket for deployment artifacts
AGENT_ENGINE_STAGING_BUCKET=gs://your-agent-engine-staging-bucket

# Optional explicit flags for local ADK runs. These are auto-derived from
# GCP_PROJECT_ID/GCP_LOCATION in bnl/agent.py if omitted.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ADK Session Persistence (optional - defaults to in-memory)
# SESSION_SERVICE_URI=sqlite:///./bnl.db

# Optional: A2A executor agent (disabled by default)
# A2A_EXECUTOR_ENABLED=false
# A2A_EXECUTOR_RESOURCE_NAME=projects/your-project-id/locations/us-central1/reasoningEngines/ENGINE_ID
